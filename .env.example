# Firebase Realtime Database config — powers the Odin online room feature.
# 1. Create a free project at https://console.firebase.google.com
# 2. Add a Web App (</> icon) to the project and copy its config values below.
# 3. In the project, go to Build > Realtime Database > Create Database.
# 4. Copy this file to .env.local and fill in the values (.env.local is gitignored).
# 5. Restart `npm run dev`.
#
# Without this, the game hub still works fully — only "Room Online" in Odin's
# multiplayer setup will show a "belum dikonfigurasi" message.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
